{
  "name": "cc-im",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --tsconfig tsconfig.json",
    "lint:fix": "oxlint --fix src --tsconfig tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "bun run typecheck && bun run lint && bun run fmt:check"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "@grammyjs/parse-mode": "^2.3.0",
    "grammy": "^1.41.1",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/markdown-it": "^14.1.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.6.3"
  }
}
